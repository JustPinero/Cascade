// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Project {
  id                 Int               @id @default(autoincrement())
  name               String
  slug               String            @unique
  path               String
  status             String            @default("building") // building | complete | deployed | backburner | paused | archived
  stack              String            @default("{}") // JSON string
  currentPhase       String            @default("phase-1-foundation")
  currentRequest     String?
  health             String            @default("idle") // healthy | warning | blocked | idle
  healthDetails      String            @default("{}") // JSON string
  githubRepo         String?
  autonomyMode       String            @default("semi") // full | semi | manual
  agentTeamsEnabled  Boolean           @default(false)
  prWorkflowEnabled  Boolean           @default(false)
  progressScore      Int               @default(0)
  progressDetails    String            @default("{}")
  deploymentInfo     String            @default("{}") // JSON: { url, provider, healthEndpoint }
  businessStage      String            @default("building") // building, pre-sale, active-sale, revenue, growth, internal
  projectContext     String?           // persisted context.md content — project story, stakeholders, goals
  completionCriteria String?           // persisted done.md content — what "done" means for this project
  badges             String            @default("[]") // JSON array: deployed, client, testing, awaiting-review, versioned
  deadline           DateTime?
  lastSessionEndedAt DateTime?
  kickoffTemplateId  Int?
  lastActivityAt     DateTime          @default(now())
  lastScannedAt      DateTime          @default(now())
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  lessons          KnowledgeLesson[]
  auditSnapshots   AuditSnapshot[]
  activityEvents   ActivityEvent[]
  humanTasks       HumanTask[]
  dispatchOutcomes DispatchOutcome[]
  dispatches       Dispatch[]
  featureUsages    ProjectFeatureUsage[]
  featureProposals FeatureProposal[]
  kickoffTemplate  KickoffTemplate?  @relation(fields: [kickoffTemplateId], references: [id])

  // Phase 31 — audit finding [30.D4]. Dashboard, briefing, and
  // overseer-tools-query-projects all `orderBy: { lastActivityAt: "desc" }`.
  @@index([lastActivityAt])
  @@index([status, lastActivityAt])
}

model KnowledgeLesson {
  id              Int       @id @default(autoincrement())
  title           String
  content         String // markdown
  category        String // deployment | auth | database | performance | testing | error-handling | integrations | anti-patterns | architecture | tooling
  sourceProjectId Int?
  sourceFile      String?
  sourcePhase     String?
  tags            String    @default("[]") // JSON array
  severity        String    @default("nice-to-know") // critical | important | nice-to-know
  discoveredAt    DateTime  @default(now())
  verified        Boolean   @default(false)
  timesReferenced Int       @default(0)

  sourceProject Project? @relation(fields: [sourceProjectId], references: [id])
}

model KickoffTemplate {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  content     String // markdown
  projectType String   @default("web-app") // web-app | game | api | mobile | other
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  projects Project[]
}

model AuditSnapshot {
  id         Int      @id @default(autoincrement())
  projectId  Int
  phase      String
  auditType  String // test-audit | bughunt | optimize | drift-audit
  grade      String?
  findings   String   @default("{}") // JSON
  isRead     Boolean  @default(false)
  capturedAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])
}

model ActivityEvent {
  id        Int      @id @default(autoincrement())
  projectId Int?
  eventType String // commit | phase-complete | audit-complete | lesson-harvested | advisory-sent | project-created | blocker-detected | debt-resolved | session-complete
  summary   String
  details   String? // JSON
  createdAt DateTime @default(now())

  project Project? @relation(fields: [projectId], references: [id])

  // Phase 31 — audit finding [30.D4]. ActivityFeed polls every 30s
  // with `orderBy: createdAt desc`; briefing filters `where: createdAt gte`.
  @@index([createdAt])
  @@index([projectId, createdAt])
}

model DispatchOutcome {
  id             Int      @id @default(autoincrement())
  projectId      Int
  projectSlug    String
  mode           String // continue, audit, investigate, custom
  healthAtDispatch String // healthy, warning, blocked, idle
  outcome        String // success, blocker, attention-needed, test-failure, unknown
  signals        String   @default("[]") // JSON array of escalation signal types detected
  dispatchedAt   DateTime
  completedAt    DateTime @default(now())
  // Phase 23.2 — link outcome to its originating Dispatch row.
  // Nullable for backfill of pre-23.2 rows; new rows must populate.
  dispatchId     String?  @unique
  // Phase 41.2 — goal-driven dispatch outcomes. goalCondition is the
  // /goal condition composed at dispatch (null for ad-hoc dispatches);
  // goalAchieved is the evaluator verdict parsed from the session log
  // (null = no verdict surfaced); goalReason is the evaluator's stated
  // reason when present.
  goalCondition  String?
  goalAchieved   Boolean?
  goalReason     String?

  project  Project   @relation(fields: [projectId], references: [id])
  dispatch Dispatch? @relation(fields: [dispatchId], references: [id])
}

// Phase 23.2 — first-class Dispatch lifecycle row.
// Written at enqueue, transitioned by the dispatcher and webhook,
// timed-out by the watchdog. The idempotencyKey is the canonical
// correlation handle between the dispatcher, the spawned Claude Code
// session (passed via CASCADE_DISPATCH_ID env), and the Stop-hook
// webhook.
model Dispatch {
  id               String           @id @default(cuid())
  idempotencyKey   String           @unique @default(cuid())
  projectId        Int
  projectSlug      String
  mode             String                                  // continue | audit | investigate | custom
  customPrompt    String?
  status           String           @default("queued")     // queued | started | completed | failed | timeout
  prompt           String?
  healthAtDispatch String?
  expectedBy       DateTime?
  enqueuedAt       DateTime         @default(now())
  startedAt        DateTime?
  completedAt      DateTime?
  errorMessage     String?

  outcome          DispatchOutcome?
  project          Project          @relation(fields: [projectId], references: [id])

  @@index([projectId, status])
  @@index([expectedBy])
  @@index([status])
}

// Phase 12A.1 — ChatSession owns conversation state.
// workingMemory is the structured session-scoped JSON document that
// the Overseer reads and writes via tools (replaces the prior
// "stuff-everything-in-the-system-prompt" pattern).
model ChatSession {
  id            String        @id @default(cuid())
  startedAt     DateTime      @default(now())
  closedAt      DateTime?
  activeFlow        String?       // "inventory_walk" | "dispatch_planning" | "incident_triage" | null
  workingMemory     String        @default("{}") // JSON string
  // Phase 12E — cached summary of the older portion of the conversation.
  // JSON: {summarizedThroughMessageCount, summary}.
  compressedHistory String?

  messages          ChatMessage[]

  @@index([startedAt])
  @@index([closedAt])
}

model ChatMessage {
  id          Int          @id @default(autoincrement())
  role        String // user | assistant
  content     String
  sessionDate String // YYYY-MM-DD, groups conversations by day
  sessionId   String?      // Phase 12A.1 — links to ChatSession; optional during transition
  toolCalls   String?      // Phase 12A.1 — JSON string of structured tool invocations
  createdAt   DateTime     @default(now())

  session     ChatSession? @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
  @@index([sessionDate])
  // Phase 31 — audit finding [30.D4]. /api/overseer/history filters
  // `where: { sessionDate }` and `orderBy: createdAt asc`.
  @@index([sessionDate, createdAt])
}

model HumanTask {
  id          Int       @id @default(autoincrement())
  title       String
  category    String    @default("other") // asset, credential, testing, deploy, review, external, other
  priority    String    @default("normal") // high, normal, low
  status      String    @default("pending") // pending, done
  projectId   Int?
  projectSlug String?
  createdBy   String    @default("claude") // claude, user, delamain
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  project Project? @relation(fields: [projectId], references: [id])

  // Phase 31 — audit finding [30.D4]. /api/tasks and /api/briefing
  // both filter on status; the list endpoint orders by (priority, createdAt).
  @@index([status, priority, createdAt])
}

model Reminder {
  id             Int      @id @default(autoincrement())
  message        String
  conditionType  String // project-health, phase-complete, project-deployed, custom
  conditionValue String // e.g., "ratracer:healthy" or "pointpartner:phase-3" or freeform
  projectSlug    String? // optional — which project this relates to
  status         String   @default("pending") // pending, triggered, dismissed
  createdBy      String   @default("delamain") // delamain or user
  createdAt      DateTime @default(now())
  triggeredAt    DateTime?
}

// Phase 11.1 — Anthropic Feature Update Check
// Vendor-agnostic catalog of upstream AI capabilities Cascade tracks.
// Defaults to "anthropic" but the schema allows future vendors.
model UpstreamFeature {
  id                 Int                    @id @default(autoincrement())
  vendor             String                 @default("anthropic")
  name               String
  category           String // hook | skill | slash-command | mcp-server | sub-agent | agent-team | settings-flag | sdk-feature | api-feature | memory | other
  description        String
  integrationRecipe  String
  source             String                 @default("manual") // "manual" | URL | "harvester"
  addedBy            String                 @default("manual") // "manual" | "harvester" | "fetch"
  confidence         Int                    @default(100) // 0-100
  detector           String? // function name in lib/anthropic-feature-detectors.ts (null if no detector yet)
  discoveredAt       DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  usages             ProjectFeatureUsage[]
  proposals          FeatureProposal[]

  @@unique([vendor, name])
}

// Per-project ledger: which features are detected as in use.
// Derived from filesystem audit; never hand-maintained.
model ProjectFeatureUsage {
  id          Int      @id @default(autoincrement())
  projectId   Int
  featureId   Int
  signal      String // free-form: where the detector matched (e.g. ".claude/settings.json hooks.Stop")
  detectedAt  DateTime @default(now())

  project Project         @relation(fields: [projectId], references: [id])
  feature UpstreamFeature @relation(fields: [featureId], references: [id])

  @@unique([projectId, featureId])
  @@index([projectId])
  @@index([featureId])
}

// Phase 11.3 — persistence for feature proposals generated by the
// Anthropic Feature Proposer. Each proposal is a Claude-drafted diff
// for a (project, missing-feature) pair. Status starts at "proposed";
// the user (or a follow-up tool) transitions to accepted/rejected/
// applied via PATCH /api/feature-proposals/[id].
model FeatureProposal {
  id          Int       @id @default(autoincrement())
  projectId   Int
  featureId   Int
  diff        String    // Claude-generated Markdown diff
  status      String    @default("proposed") // proposed | accepted | rejected | applied
  generatedAt DateTime  @default(now())
  resolvedAt  DateTime?
  resolvedBy  String?   // "user" | "claude" | "system"
  notes       String?

  project Project         @relation(fields: [projectId], references: [id])
  feature UpstreamFeature @relation(fields: [featureId], references: [id])

  @@index([projectId])
  @@index([featureId])
  @@index([status])
  @@index([generatedAt])
}

// Phase 24.2 — Tool-call observability.
// One row per `registry.execute(...)` invocation in runToolUseLoop.
// Drives /observability/tools and the `get_tool_call_stats` tool. The
// `resultUsed` column is reserved for a follow-up heuristic; default
// true so absence-of-data doesn't penalize tools.
model ToolCallEvent {
  id            Int      @id @default(autoincrement())
  sessionId     String
  iteration     Int
  toolName      String
  input         String   // JSON, truncated to 4 KB
  outputSize    Int
  success       Boolean
  errorMessage  String?
  durationMs    Int
  resultUsed    Boolean? @default(true)
  createdAt     DateTime @default(now())

  @@index([sessionId, createdAt])
  @@index([toolName])
  @@index([createdAt])
}

// Phase 23.3 — Anthropic API usage telemetry.
// Fire-and-forget row written by every Anthropic call site. Drives
// /observability/cache hit-rate visibility and protects 23.4's
// caching rollout from silent regressions.
model AnthropicUsageEvent {
  id                        Int      @id @default(autoincrement())
  callSite                  String   // "overseer.chat" | "summarizer" | "feature-proposer" | "wizard" | "project.chat"
  model                     String
  inputTokens               Int
  cacheReadInputTokens      Int      @default(0)
  cacheCreationInputTokens  Int      @default(0)
  cacheCreation5mTokens     Int      @default(0)
  cacheCreation1hTokens     Int      @default(0)
  outputTokens              Int
  durationMs                Int
  createdAt                 DateTime @default(now())

  @@index([callSite, createdAt])
  @@index([createdAt])
  @@index([model])
}

// Single-row config table for Cascade-wide state.
// First use: track lastSeenClaudeCodeVersion for the version watcher.
model CascadeConfig {
  id                         Int       @id @default(1) // single-row enforced by always upserting id=1
  lastSeenClaudeCodeVersion  String?
  updatedAt                  DateTime  @updatedAt
}

// ── Phase 43 — Teams foundation ─────────────────────────────────────
// Multi-user identity primitives. Additive + backward-compatible:
// existing single-user data has no Team and is unaffected. Auth (how a
// User authenticates) is a later, gated phase — a User here is identity
// only. See docs/cascade-2.0-team-direction.md.

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String
  createdAt DateTime @default(now())

  memberships    Membership[]
  createdTeams   Team[]       @relation("TeamCreatedBy")
  sentInvites    Invite[]     @relation("InviteInvitedBy")
}

model Team {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  createdById Int
  createdAt   DateTime @default(now())

  createdBy   User         @relation("TeamCreatedBy", fields: [createdById], references: [id])
  memberships Membership[]
  invites     Invite[]
}

model Membership {
  id        Int      @id @default(autoincrement())
  userId    Int
  teamId    Int
  role      String   @default("member") // owner | admin | member | viewer
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  team Team @relation(fields: [teamId], references: [id])

  @@unique([userId, teamId])
  @@index([teamId])
}

model Invite {
  id          Int       @id @default(autoincrement())
  teamId      Int
  email       String
  role        String    @default("member") // owner | admin | member | viewer
  token       String    @unique
  invitedById Int
  status      String    @default("pending") // pending | accepted | revoked | expired
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  team      Team @relation(fields: [teamId], references: [id])
  invitedBy User @relation("InviteInvitedBy", fields: [invitedById], references: [id])

  @@unique([teamId, email])
  @@index([token])
}
